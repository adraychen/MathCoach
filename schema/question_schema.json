{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MathCoach Question Schema",
  "description": "Structured schema for AI-generated and curated math questions",
  "type": "object",
  "required": [
    "id",
    "program",
    "topic",
    "subtopic",
    "difficulty",
    "archetype",
    "question_text",
    "options",
    "correct_answer",
    "reasoning_skills",
    "misconceptions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier: {program}_{topic}_{difficulty}_{sequence}",
      "pattern": "^[a-z_]+_[a-z_]+_[a-z]+_[0-9]{4}$",
      "examples": ["waterloo_gauss_factors_multiples_primes_part_a_0001"]
    },
    "program": {
      "type": "string",
      "description": "Reference to program.id from programs.json",
      "enum": ["waterloo_gauss", "waterloo_pascal", "amc_8", "singapore_math"]
    },
    "topic": {
      "type": "string",
      "description": "Reference to topic.id from topics.json",
      "enum": [
        "number_sense",
        "arithmetic_operations",
        "fractions_decimals_percents",
        "factors_multiples_primes",
        "patterns_sequences",
        "algebra_equations",
        "geometry_measurement",
        "counting_probability",
        "logic_reasoning",
        "word_problems",
        "model_method"
      ]
    },
    "subtopic": {
      "type": "string",
      "description": "Reference to subtopic.id within the topic"
    },
    "difficulty": {
      "type": "string",
      "description": "Reference to difficulty_level.id from difficulty_levels.json",
      "enum": ["part_a", "part_b", "part_c", "easy", "medium", "hard", "foundation", "standard", "challenge"]
    },
    "archetype": {
      "type": "string",
      "description": "Reference to archetype.id from archetypes.json"
    },
    "question_text": {
      "type": "string",
      "description": "The question stem, supports LaTeX via $...$ delimiters"
    },
    "options": {
      "type": "object",
      "description": "Multiple choice options A-E",
      "properties": {
        "A": { "type": "string" },
        "B": { "type": "string" },
        "C": { "type": "string" },
        "D": { "type": "string" },
        "E": { "type": "string" }
      },
      "required": ["A", "B", "C", "D", "E"]
    },
    "correct_answer": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "E"]
    },
    "reasoning_skills": {
      "type": "array",
      "description": "Primary reasoning skills required (reference reasoning_skills.id)",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 3
    },
    "misconceptions": {
      "type": "array",
      "description": "Likely misconceptions (reference misconceptions.id)",
      "items": { "type": "string" }
    },
    "distractor_rationale": {
      "type": "object",
      "description": "Why each wrong answer might be chosen",
      "properties": {
        "A": { "type": "string" },
        "B": { "type": "string" },
        "C": { "type": "string" },
        "D": { "type": "string" },
        "E": { "type": "string" }
      }
    },
    "solution": {
      "type": "object",
      "description": "Step-by-step solution for coaching",
      "properties": {
        "steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "key_insight": {
          "type": "string",
          "description": "The main conceptual insight needed"
        },
        "common_approach": {
          "type": "string",
          "description": "How most students would solve this"
        },
        "elegant_approach": {
          "type": "string",
          "description": "A more efficient or insightful method"
        }
      },
      "required": ["steps", "key_insight"]
    },
    "coaching_hints": {
      "type": "array",
      "description": "Progressive hints from least to most revealing",
      "items": { "type": "string" },
      "minItems": 2,
      "maxItems": 4
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata for analytics and generation",
      "properties": {
        "source": {
          "type": "string",
          "enum": ["human_authored", "ai_generated", "adapted"],
          "description": "Origin of the question"
        },
        "source_reference": {
          "type": "string",
          "description": "Original source if adapted (e.g., 'Gauss 2023 Q5')"
        },
        "estimated_time_seconds": {
          "type": "integer",
          "minimum": 15,
          "maximum": 600
        },
        "cognitive_load": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "computation_required": {
          "type": "string",
          "enum": ["none", "simple", "moderate", "complex"]
        },
        "diagram_required": {
          "type": "boolean"
        },
        "diagram_url": {
          "type": "string",
          "description": "Path to diagram asset if required"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "validated": {
          "type": "boolean"
        },
        "validation_notes": {
          "type": "string"
        }
      }
    },
    "generation_params": {
      "type": "object",
      "description": "Parameters used if AI-generated, for reproducibility",
      "properties": {
        "template_id": { "type": "string" },
        "seed_values": { "type": "object" },
        "variation_of": { "type": "string" }
      }
    },
    "analytics": {
      "type": "object",
      "description": "Performance data (populated after student attempts)",
      "properties": {
        "attempt_count": { "type": "integer" },
        "success_rate": { "type": "number" },
        "avg_time_seconds": { "type": "number" },
        "most_selected_wrong": { "type": "string" },
        "coaching_request_rate": { "type": "number" }
      }
    }
  }
}
